					},
					"response": []
				},
				{
					"name": "Delete User By ID",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/admin/users/:id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"admin",
								"users",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "651f67f893fa910f545a9098",
									"description": "The unique MongoDB ObjectID of the user to be deleted."
								}
							]
						},
						"description": "Permanently delete a user from the system by their ID. Requires Admin token."
					},
					"response": []
				}
			]
		}
	]
}
