{
  "info": {
    "name": "Smart Trip Planner API",
    "description": "Complete API request collection for the Smart Trip Planner backend services. Includes all authentication, admin panel, destinations management, contact messages, testimonials, and image uploading APIs. Features a test script in the Login request that automatically saves the returned JWT token to the {{token}} variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "description": "User registration, authentication, and profile endpoints.",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aisha Sharma\",\n  \"email\": \"aisha@example.com\",\n  \"phone\": \"9876543210\",\n  \"aadharNumber\": \"987654321012\",\n  \"password\": \"Password1@\",\n  \"role\": \"user\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login User / Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data && response.data.token) {",
                  "    pm.collectionVariables.set(\"token\", response.data.token);",
                  "    console.log(\"Token auto-saved to {{token}} variable successfully!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
