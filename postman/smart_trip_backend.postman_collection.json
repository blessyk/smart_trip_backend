								"{{base_url}}"
							],
							"path": [
								"admin",
								"users",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "651f67f893fa910f545a9098",
									"description": "The unique MongoDB ObjectID of the target user."
								}
							]
						},
